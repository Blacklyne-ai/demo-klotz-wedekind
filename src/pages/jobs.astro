---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { site, telLink } from '../data/site';

const ausbildung = [
  {
    title: 'Kfz-Mechatroniker (m/w/d) - Nutzfahrzeuge',
    body: 'Klassische Ausbildung zum Kfz-Mechatroniker mit Schwerpunkt Nutzfahrzeug-Technik. Mechanik, Elektrik, Hydraulik, Diagnose - alles im Werkstatt-Alltag bei den großen Brummern.',
    iconName: 'Settings',
  },
  {
    title: 'Karosserie- & Fahrzeugbau (m/w/d) - Karosserietechnik',
    body: 'Karosseriebau aus 115 Jahren Tradition. Sonderaufbauten, Kühlfahrzeuge, Pritschen - hier wird noch nach Maß gearbeitet.',
    iconName: 'Hammer',
  },
];

const stellen = [
  { title: 'Kfz-Mechatroniker (m/w/d) - Nutzfahrzeuge', iconName: 'Settings' },
  { title: 'Karosseriebauer (m/w/d) - Nutzfahrzeuge',   iconName: 'Hammer' },
  { title: 'Kfz-Elektriker (m/w/d) - Nutzfahrzeuge',    iconName: 'Cpu' },
  { title: 'Hydrauliker (m/w/d) - Nutzfahrzeuge',       iconName: 'Zap' },
  { title: 'Land- &amp; Baumaschinenmechaniker (m/w/d)', iconName: 'Wrench' },
];
---

<Layout
  title={`Jobs - ${site.name}`}
  description="Stellenangebote und Ausbildungsplätze bei Klotz + Wedekind in Hamburg-Wilhelmsburg. Kfz-Mechatroniker, Karosseriebauer, Elektriker, Hydrauliker."
  current="jobs"
>

  <!-- Hero -->
  <section class="subpage-hero ink-grid">
    <div class="container-rd relative pt-32 md:pt-40 pb-12 md:pb-16">
      <div class="max-w-3xl">
        <span class="eyebrow eyebrow-light">Team verstärken · Hamburg-Wilhelmsburg</span>
        <h1 class="heading-display mt-4 text-balance" style="color:#fff">
          Werden Sie Teil
          <span class="accent-brand"> unseres Teams.</span>
        </h1>
        <p class="lead-on-dark mt-5 max-w-2xl text-pretty">
          115 Jahre Tradition, drei Generationen Familie Wedekind, GTÜ-Stützpunkt und eine 20 m
          Lackieranlage - bei uns arbeiten Sie am ganzen Spektrum moderner Nutzfahrzeug-Technik.
        </p>
      </div>
    </div>
  </section>

  <!-- Ausbildung -->
  <section class="section">
    <div class="container-rd">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow">Ausbildung · Bewerbung ab 01.01. für 01.08.</span>
        <h2 class="heading-xl mt-4 text-balance">
          Ausbildung
          <span class="accent-brand"> bei Klotz + Wedekind.</span>
        </h2>
        <p class="lead mt-5 text-pretty">
          Wir bilden in zwei Berufen aus - in einem Betrieb mit 115 Jahren Erfahrung und einem
          Team aus Meistern, die ihr Wissen teilen.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {ausbildung.map((a) => (
          <article class="job-card">
            <span class="job-card-icon"><Icon name={a.iconName} size={26} strokeWidth={1.9} /></span>
            <span class="job-card-cat">Ausbildung</span>
            <h3 class="job-card-title">{a.title}</h3>
            <p class="job-card-body">{a.body}</p>
            <div class="job-card-meta">
              <Icon name="GraduationCap" size={15} strokeWidth={2} />
              <span>Sehr gute Hauptschule oder gute Mittlere Reife</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Aktuelle Stellen -->
  <section class="section section-paper-deep">
    <div class="container-rd">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow">Aktuelle Stellen · alle (m/w/d)</span>
        <h2 class="heading-xl mt-4 text-balance">
          Wir suchen
          <span class="accent-brand"> verstärkung.</span>
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {stellen.map((s) => (
          <div class="stelle-card">
            <span class="stelle-card-icon"><Icon name={s.iconName} size={20} strokeWidth={2} /></span>
            <span class="stelle-card-title" set:html={s.title} />
          </div>
        ))}
      </div>

      <p class="text-center text-muted text-sm mt-10">
        Alle Stellen mit Schwerpunkt LKW-Bereich.
      </p>
    </div>
  </section>

  <!-- Bewerbung -->
  <section class="section">
    <div class="container-rd">
      <div class="bewerbung-card">
        <div>
          <span class="eyebrow">Bewerbung</span>
          <h2 class="heading-lg mt-4">
            Ihre Bewerbung an
            <span class="accent-brand"> Frau Anja Mädel.</span>
          </h2>
          <p class="lead mt-5 text-pretty">
            Bewerbungen, Praktikumsanfragen und alle Fragen rund um Ausbildung beantwortet Anja Mädel.
            Schicken Sie Ihre Unterlagen einfach per E-Mail oder Post.
          </p>
        </div>

        <div class="bewerbung-contacts">
          <a href={`mailto:${site.emailBewerbung}`} class="bewerbung-row">
            <span class="bewerbung-icon"><Icon name="Mail" size={18} strokeWidth={2.2} /></span>
            <div>
              <span class="bewerbung-label">E-Mail</span>
              <strong class="bewerbung-value">{site.emailBewerbung}</strong>
            </div>
          </a>
          <a href="tel:+494073483150" class="bewerbung-row">
            <span class="bewerbung-icon"><Icon name="Phone" size={18} strokeWidth={2.2} /></span>
            <div>
              <span class="bewerbung-label">Telefon Anja Mädel</span>
              <strong class="bewerbung-value">040 - 734 83 - 150</strong>
            </div>
          </a>
          <div class="bewerbung-row bewerbung-row-static">
            <span class="bewerbung-icon"><Icon name="MapPin" size={18} strokeWidth={2.2} /></span>
            <div>
              <span class="bewerbung-label">Post</span>
              <strong class="bewerbung-value">Stenzelring 9, 21107 Hamburg</strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta ink-grid">
    <div class="container-rd relative">
      <div class="text-center max-w-3xl mx-auto">
        <span class="eyebrow eyebrow-light">Werden Sie Teil der Geschichte</span>
        <h2 class="heading-xl mt-4 text-balance" style="color:#fff">
          Drei Generationen.
          <span class="accent-brand"> Ihr Platz?</span>
        </h2>
        <p class="lead-on-dark mt-5 text-pretty">
          Wir freuen uns auf Ihre Bewerbung. Per E-Mail an Anja Mädel oder ein Anruf vorher zum Kennenlernen.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a href={`mailto:${site.emailBewerbung}`} class="btn btn-primary btn-lg">
            <Icon name="Mail" size={17} strokeWidth={2.2} />
            Jetzt bewerben
          </a>
          <a href={telLink} class="btn btn-on-dark btn-lg">
            <Icon name="Phone" size={17} strokeWidth={2.2} />
            Erst anrufen
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .job-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem 1.85rem;
    background: linear-gradient(135deg, #fff 0%, rgb(var(--rgb-paper)) 100%);
    border: 1px solid rgb(var(--rgb-line));
    border-radius: var(--r-lg);
    transition: transform 0.3s ease, border-color 0.25s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }
  .job-card:hover {
    transform: translateY(-3px);
    border-color: rgb(var(--rgb-brand) / 0.36);
    box-shadow: 0 16px 40px -16px rgb(23 23 23 / 0.18);
  }
  .job-card-icon {
    width: 54px; height: 54px;
    border-radius: var(--r-md);
    background: linear-gradient(135deg, rgb(var(--rgb-brand) / 0.14), rgb(var(--rgb-accent) / 0.08));
    border: 1px solid rgb(var(--rgb-brand) / 0.22);
    color: rgb(var(--rgb-brand));
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 0.5rem;
  }
  .job-card-cat {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(var(--rgb-brand));
  }
  .job-card-title {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 1.2rem;
    line-height: 1.2;
    color: rgb(var(--rgb-ink));
    letter-spacing: -0.012em;
    margin: 0;
  }
  .job-card-body {
    color: rgb(var(--rgb-ink-soft));
    font-size: 0.94rem;
    line-height: 1.55;
    margin: 0.35rem 0 1rem;
  }
  .job-card-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    background: rgb(var(--rgb-brand) / 0.06);
    border-radius: 8px;
    color: rgb(var(--rgb-brand-deep));
    font-size: 0.82rem;
    font-weight: 600;
    width: fit-content;
  }

  .stelle-card {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1.25rem 1.35rem;
    background: #fff;
    border: 1px solid rgb(var(--rgb-line));
    border-radius: 12px;
    transition: transform 0.2s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .stelle-card:hover {
    transform: translateY(-2px);
    border-color: rgb(var(--rgb-brand) / 0.4);
    box-shadow: 0 12px 28px -10px rgb(23 23 23 / 0.14);
  }
  .stelle-card-icon {
    width: 40px; height: 40px;
    border-radius: 9px;
    background: rgb(var(--rgb-brand) / 0.08);
    color: rgb(var(--rgb-brand));
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .stelle-card-title {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 0.95rem;
    color: rgb(var(--rgb-ink));
    letter-spacing: -0.008em;
    line-height: 1.25;
  }

  .bewerbung-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 2.5rem 2.25rem;
    background: linear-gradient(135deg, #fff 0%, rgb(var(--rgb-paper)) 100%);
    border: 1px solid rgb(var(--rgb-line));
    border-radius: var(--r-lg);
    box-shadow: 0 18px 44px -18px rgb(23 23 23 / 0.18);
  }
  @media (min-width: 768px) {
    .bewerbung-card { grid-template-columns: 1.05fr 0.95fr; gap: 3rem; }
  }
  .bewerbung-contacts { display: flex; flex-direction: column; gap: 0.65rem; }
  .bewerbung-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
    background: rgb(var(--rgb-paper-50));
    border: 1px solid rgb(var(--rgb-line));
    border-radius: 10px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .bewerbung-row:hover:not(.bewerbung-row-static) {
    transform: translateX(3px);
    border-color: rgb(var(--rgb-brand) / 0.4);
  }
  .bewerbung-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    background: rgb(var(--rgb-brand) / 0.1);
    color: rgb(var(--rgb-brand));
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .bewerbung-label {
    display: block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--rgb-muted));
    margin-bottom: 1px;
  }
  .bewerbung-value {
    display: block;
    font-family: var(--font-headline);
    font-size: 0.98rem;
    font-weight: 800;
    color: rgb(var(--rgb-ink));
    letter-spacing: -0.008em;
    word-break: break-all;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { site, telLink } from '../data/site';

const ausbildung = [
  {
    slug: 'ausb-mechatroniker',
    title: 'Kfz-Mechatroniker/in - Nutzfahrzeuge',
    cat: 'Ausbildung · 3,5 Jahre',
    iconName: 'Settings',
    intro: 'Klassische Ausbildung zum Kfz-Mechatroniker mit Schwerpunkt Nutzfahrzeug-Technik. Mechanik, Elektrik, Hydraulik, Diagnose - alles im Werkstatt-Alltag bei LKW und Transportern.',
    aufgaben: [
      'Wartungs- und Servicearbeiten an LKW und Anhängern',
      'Diagnose mit moderner Werkstatt-Software',
      'Hydraulik-Einbauten und Reparaturen',
      'Bremsen-Service nach §29 StVZO',
      'HU-Vorbereitung und Begleitung',
    ],
    voraussetzungen: [
      'Sehr guter Hauptschulabschluss oder guter Realschulabschluss',
      'Interesse an Mechanik, Elektrik und großen Fahrzeugen',
      'Sorgfalt und Verantwortungsbewusstsein',
      'Teamfähigkeit und Lernbereitschaft',
    ],
  },
  {
    slug: 'ausb-karosseriebauer',
    title: 'Karosserie- & Fahrzeugbauer/in - Karosserietechnik',
    cat: 'Ausbildung · 3,5 Jahre',
    iconName: 'Hammer',
    intro: 'Karosseriebau aus 115 Jahren Tradition. Sonderaufbauten, Kühlfahrzeuge, Pritschen, Krane - hier wird noch nach Maß gearbeitet, mit modernster Technik.',
    aufgaben: [
      'Aufbauten an LKW und Anhängern',
      'Schweißarbeiten an Stahl und Aluminium',
      'Sonderanfertigungen nach Kundenwunsch',
      'Reparatur von Karosserie-Schäden',
      'Rahmen-Richtarbeiten am Hydraulik-Stand',
    ],
    voraussetzungen: [
      'Sehr guter Hauptschulabschluss oder guter Realschulabschluss',
      'Handwerkliches Geschick',
      'Räumliches Vorstellungsvermögen',
      'Interesse an Konstruktion und Technik',
    ],
  },
];

const stellen = [
  {
    slug: 'kfz-mechatroniker',
    title: 'Kfz-Mechatroniker/in (m/w/d)',
    cat: 'Vollzeit · Nutzfahrzeuge',
    iconName: 'Settings',
    intro: 'Sie sind Mechatroniker mit Erfahrung im Nutzfahrzeug-Bereich? Bei uns arbeiten Sie an LKW, Transportern, Anhängern und Aufliegern - vom Bremsen-Service bis zur Software-Diagnose.',
    aufgaben: [
      'Wartung und Reparatur an LKW, Transportern, Anhängern und Aufliegern',
      'Bremsen-Service nach §29 StVZO',
      'Mechatronik, Motor- und Getriebeinstandsetzung',
      'Software- und Fehlerdiagnose',
      'HU-Begleitung als GTÜ-Stützpunkt',
    ],
    voraussetzungen: [
      'Abgeschlossene Ausbildung als Kfz-Mechatroniker oder vergleichbar',
      'Erfahrung im Nutzfahrzeug-Bereich erwünscht',
      'Führerschein Klasse B (Klasse C/CE von Vorteil)',
      'Selbstständige und sorgfältige Arbeitsweise',
    ],
  },
  {
    slug: 'karosseriebauer',
    title: 'Karosseriebauer/in (m/w/d)',
    cat: 'Vollzeit · Nutzfahrzeuge',
    iconName: 'Hammer',
    intro: 'Sie sind Karosseriebauer mit Auge für saubere Arbeit? Bei uns ist Karosserie nicht nur Reparatur - hier entstehen auch echte Sonderanfertigungen für Spediteure und Fuhrpark-Manager.',
    aufgaben: [
      'Karosseriereparatur an LKW und Aufbauten',
      'Schweißarbeiten Stahl und Aluminium',
      'Unfallinstandsetzung mit Versicherungsabwicklung',
      'Sonderaufbauten nach Kundenspezifikation',
      'Rahmenrichten am hydraulischen Stand',
    ],
    voraussetzungen: [
      'Abgeschlossene Ausbildung Karosserie- und Fahrzeugbauer oder vergleichbar',
      'Sicheres Schweißen (MAG, MIG, WIG)',
      'Erfahrung mit Nutzfahrzeugen von Vorteil',
      'Saubere und präzise Arbeitsweise',
    ],
  },
  {
    slug: 'kfz-elektriker',
    title: 'Kfz-Elektriker/in (m/w/d)',
    cat: 'Vollzeit · Nutzfahrzeuge',
    iconName: 'Cpu',
    intro: 'Elektrik und Elektronik an Nutzfahrzeugen werden immer komplexer. Sie sind der Spezialist, der Bordnetze, Telematik und Beleuchtungs-Systeme zuverlässig zum Laufen bringt.',
    aufgaben: [
      'Elektrik- und Elektronik-Reparaturen an LKW und Aufbauten',
      'Bordnetz-Erweiterungen und Sonder-Einbauten',
      'Fehlerdiagnose mit Werkstatt-Tester',
      'Telematik und Beleuchtungs-Systeme',
      'Verkabelung von Krane und Ladebordwänden',
    ],
    voraussetzungen: [
      'Abgeschlossene Ausbildung Kfz-Elektriker, Mechatroniker oder vergleichbar',
      'Erfahrung mit Nutzfahrzeug-Elektrik wünschenswert',
      'Strukturierte Fehlersuche',
      'Lust auf Weiterbildung in neuer Fahrzeugtechnik',
    ],
  },
  {
    slug: 'hydrauliker',
    title: 'Hydrauliker/in (m/w/d)',
    cat: 'Vollzeit · Nutzfahrzeuge',
    iconName: 'Zap',
    intro: 'Krane von Hiab und Palfinger, Ladebordwände von Bär, Dhollandia oder Sörensen, Kippsysteme von Hyva - Hydraulik ist Ihre Welt? Dann passen Sie zu uns.',
    aufgaben: [
      'Reparatur und Wartung von Krane, Ladebordwänden und Kipper-Systemen',
      'UVV-Prüfungen mit Dokumentation',
      'Hydraulik-Schlauch und Pumpen-Service',
      'Inbetriebnahme von Sonderaufbauten',
      'Fehlersuche und Diagnose an Hydraulik-Systemen',
    ],
    voraussetzungen: [
      'Abgeschlossene Ausbildung mit Hydraulik-Bezug (Industriemechaniker, Mechatroniker)',
      'Erfahrung mit Krane, Ladebordwänden oder Kipper-Systemen',
      'Schulungen von Hiab, Palfinger, Bär, Dhollandia o. ä. von Vorteil',
      'Sicherheitsbewusste Arbeitsweise',
    ],
  },
  {
    slug: 'landmaschinen',
    title: 'Land- und Baumaschinen-Mechaniker/in (m/w/d)',
    cat: 'Vollzeit · Sonderfahrzeuge',
    iconName: 'Wrench',
    intro: 'Landmaschinen, Baumaschinen, Sonderfahrzeuge - Sie sind die Universalkraft, wenn es um große Geräte abseits der LKW geht. Bei uns kombiniert mit Karosserie- und Hydraulik-Know-how.',
    aufgaben: [
      'Reparatur und Wartung von Land- und Baumaschinen',
      'Hydraulik- und Mechanik-Service',
      'Schweißarbeiten und Reparatur-Aufbauten',
      'Unterstützung bei Sondereinbauten',
      'Vor-Ort-Einsätze bei Bedarf',
    ],
    voraussetzungen: [
      'Abgeschlossene Ausbildung Land-/Baumaschinen-Mechaniker oder vergleichbar',
      'Erfahrung mit Hydraulik und Dieselmotoren',
      'Selbstständige Arbeitsweise',
      'Führerschein Klasse B (C/CE wünschenswert)',
    ],
  },
];

const benefits = [
  { icon: 'Award',    title: 'Heritage-Betrieb',     text: '115 Jahre Klotz + Wedekind. Familiengeführt in dritter Generation - kein anonymer Konzern.' },
  { icon: 'Settings', title: 'Top-Werkzeug',         text: 'Modernste Werkstatt-Ausstattung, Diagnose-Tester aller großen Hersteller, 20 m Lackieranlage.' },
  { icon: 'GraduationCap', title: 'Weiterbildung',   text: 'Regelmäßige Hersteller-Schulungen bei Hiab, Palfinger, Bär, Dhollandia, WABCO und Carrier.' },
  { icon: 'Users',    title: 'Persönliches Team',    text: 'Kein Schichtarbeit-Karussell. Direkte Ansprechpartner, Anja Mädel ist persönlich für Sie da.' },
  { icon: 'MapPin',   title: 'Hamburg-Wilhelmsburg', text: 'Verkehrsgünstig zwischen A1, A7 und Hafen. Mit dem Auto, ÖPNV oder Fahrrad gut erreichbar.' },
  { icon: 'Coffee',   title: 'Solide Arbeitszeiten', text: 'Mo - Fr 07:00-18:00, Sa 07:00-13:00. Geregelte Pausen, faire Bezahlung, Tarif-Anlehnung.' },
];
---

<Layout
  title={`Jobs - ${site.name} Hamburg-Wilhelmsburg`}
  description="Stellenangebote und Ausbildungsplätze bei Klotz + Wedekind in Hamburg-Wilhelmsburg. Kfz-Mechatroniker, Karosseriebauer, Elektriker, Hydrauliker. Bewerbung an Anja Mädel."
  current="jobs"
>

  <!-- Hero mit Werkstatt-Bild -->
  <section class="subpage-hero-img">
    <div class="subpage-hero-img-bg">
      <img src="/images/werkstatt.jpg" alt="Klotz + Wedekind Werkstatt in Hamburg-Wilhelmsburg" loading="eager" fetchpriority="high" />
      <div class="subpage-hero-img-overlay"></div>
    </div>
    <div class="container-rd relative pt-32 md:pt-44 pb-14 md:pb-20">
      <div class="max-w-3xl relative z-10">
        <span class="eyebrow eyebrow-light">
          <span class="eyebrow-icon"><Icon name="UserPlus" size={14} strokeWidth={2.2} /></span>
          Wir verstärken unser Team in Wilhelmsburg
        </span>
        <h1 class="heading-display mt-4 text-balance" style="color:#fff">
          Werden Sie Teil der
          <span class="accent-brand"> Klotz + Wedekind Familie.</span>
        </h1>
        <p class="lead-on-dark mt-5 max-w-2xl text-pretty">
          115 Jahre Tradition, drei Generationen Familie Wedekind, GTÜ-Stützpunkt und eine 20 m
          Lackieranlage. Sieben offene Stellen + zwei Ausbildungsplätze. Hier arbeiten Sie am ganzen
          Spektrum moderner Nutzfahrzeug-Technik.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a href={`mailto:${site.emailBewerbung}?subject=${encodeURIComponent('Bewerbung Klotz+Wedekind')}`} class="btn btn-primary btn-lg">
            <Icon name="Mail" size={17} strokeWidth={2.2} />
            Jetzt bewerben
          </a>
          <a href="#stellen" class="btn btn-on-dark btn-lg">
            Stellen ansehen
            <Icon name="ArrowDown" size={17} strokeWidth={2.2} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats-Strip -->
  <section class="section-sm">
    <div class="container-rd">
      <div class="jobs-stats">
        <div class="jobs-stat">
          <span class="jobs-stat-value">7</span>
          <span class="jobs-stat-label">Offene Stellen</span>
        </div>
        <div class="jobs-stat">
          <span class="jobs-stat-value">2</span>
          <span class="jobs-stat-label">Ausbildungsplätze</span>
        </div>
        <div class="jobs-stat">
          <span class="jobs-stat-value">115+</span>
          <span class="jobs-stat-label">Jahre Tradition</span>
        </div>
        <div class="jobs-stat">
          <span class="jobs-stat-value">3</span>
          <span class="jobs-stat-label">Generationen Wedekind</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stellen-Details -->
  <section id="stellen" class="section">
    <div class="container-rd">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="eyebrow">Offene Stellen · alle (m/w/d)</span>
        <h2 class="heading-xl mt-4 text-balance">
          Wir suchen Verstärkung
          <span class="accent-brand"> in fünf Bereichen.</span>
        </h2>
        <p class="lead mt-5 text-pretty">
          Jede Stelle mit klarem Aufgabenprofil und persönlichem Ansprechpartner. Schnelle Rückmeldung,
          ehrliche Gespräche - so machen wir das.
        </p>
      </div>

      <div class="job-list">
        {stellen.map((s) => (
          <article id={s.slug} class="job-detail-card">
            <div class="job-detail-head">
              <span class="job-detail-icon"><Icon name={s.iconName} size={26} strokeWidth={1.9} /></span>
              <div>
                <span class="job-detail-cat">{s.cat}</span>
                <h3 class="job-detail-title">{s.title}</h3>
              </div>
            </div>
            <p class="job-detail-intro">{s.intro}</p>

            <div class="job-detail-grid">
              <div class="job-detail-col">
                <span class="job-detail-h">Ihre Aufgaben</span>
                <ul class="job-detail-list">
                  {s.aufgaben.map((a) => (
                    <li><span class="job-detail-check"><Icon name="Check" size={12} strokeWidth={3} /></span>{a}</li>
                  ))}
                </ul>
              </div>
              <div class="job-detail-col">
                <span class="job-detail-h">Ihr Profil</span>
                <ul class="job-detail-list">
                  {s.voraussetzungen.map((v) => (
                    <li><span class="job-detail-dot"></span>{v}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="job-detail-cta">
              <a href={`mailto:${site.emailBewerbung}?subject=${encodeURIComponent('Bewerbung ' + s.title)}`} class="btn btn-primary">
                <Icon name="Mail" size={15} strokeWidth={2.2} />
                Auf diese Stelle bewerben
              </a>
              <a href={`tel:${site.geschaeftsfuehrung[1].phoneTel.replace('tel:', '')}`} class="btn btn-outline">
                <Icon name="Phone" size={15} strokeWidth={2.2} />
                Erst anrufen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Ausbildung -->
  <section class="section section-paper-deep">
    <div class="container-rd">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow">Ausbildung · Bewerbung ab 01.01. für 01.08.</span>
        <h2 class="heading-xl mt-4 text-balance">
          Starten Sie Ihre Karriere
          <span class="accent-brand"> bei uns.</span>
        </h2>
        <p class="lead mt-5 text-pretty">
          Wir bilden in zwei Berufen aus - in einem Betrieb mit 115 Jahren Erfahrung und einem
          Team aus Meistern, die ihr Wissen teilen. Mehr als „nur Schraube reindrehen".
        </p>
      </div>

      <div class="job-list">
        {ausbildung.map((a) => (
          <article id={a.slug} class="job-detail-card job-detail-card-ausbildung">
            <div class="job-detail-head">
              <span class="job-detail-icon"><Icon name={a.iconName} size={26} strokeWidth={1.9} /></span>
              <div>
                <span class="job-detail-cat">{a.cat}</span>
                <h3 class="job-detail-title">{a.title}</h3>
              </div>
            </div>
            <p class="job-detail-intro">{a.intro}</p>

            <div class="job-detail-grid">
              <div class="job-detail-col">
                <span class="job-detail-h">Das lernen Sie</span>
                <ul class="job-detail-list">
                  {a.aufgaben.map((x) => (
                    <li><span class="job-detail-check"><Icon name="Check" size={12} strokeWidth={3} /></span>{x}</li>
                  ))}
                </ul>
              </div>
              <div class="job-detail-col">
                <span class="job-detail-h">Voraussetzungen</span>
                <ul class="job-detail-list">
                  {a.voraussetzungen.map((v) => (
                    <li><span class="job-detail-dot"></span>{v}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="job-detail-cta">
              <a href={`mailto:${site.emailBewerbung}?subject=${encodeURIComponent('Bewerbung Ausbildung ' + a.title)}`} class="btn btn-primary">
                <Icon name="GraduationCap" size={15} strokeWidth={2.2} />
                Ausbildungsplatz sichern
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Was wir bieten -->
  <section class="section">
    <div class="container-rd">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow">Was Sie bei uns erwartet</span>
        <h2 class="heading-xl mt-4 text-balance">
          Sechs gute Gründe
          <span class="accent-brand"> für Klotz + Wedekind.</span>
        </h2>
      </div>

      <div class="benefit-grid">
        {benefits.map((b) => (
          <div class="benefit-card">
            <span class="benefit-card-icon"><Icon name={b.icon} size={24} strokeWidth={1.9} /></span>
            <strong class="benefit-card-title">{b.title}</strong>
            <p class="benefit-card-text">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bewerbungs-Pfad -->
  <section class="section section-paper-deep">
    <div class="container-rd">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow">So bewerben Sie sich</span>
        <h2 class="heading-xl mt-4 text-balance">
          Drei Schritte
          <span class="accent-brand"> zum Vorstellungsgespräch.</span>
        </h2>
      </div>

      <div class="apply-steps">
        <div class="apply-step">
          <span class="apply-step-num">01</span>
          <strong class="apply-step-title">E-Mail an Anja Mädel</strong>
          <p class="apply-step-text">Lebenslauf und kurzes Anschreiben an <a href={`mailto:${site.emailBewerbung}`}>{site.emailBewerbung}</a> - kein langes Anschreiben nötig.</p>
        </div>
        <div class="apply-step">
          <span class="apply-step-num">02</span>
          <strong class="apply-step-title">Kurz-Rückmeldung</strong>
          <p class="apply-step-text">Innerhalb von 5 Werktagen melden wir uns. Telefonisch oder per E-Mail - je nachdem was Ihnen lieber ist.</p>
        </div>
        <div class="apply-step">
          <span class="apply-step-num">03</span>
          <strong class="apply-step-title">Probetag &amp; Vertrag</strong>
          <p class="apply-step-text">Beim Vorstellungsgespräch lernen Sie die Werkstatt kennen. Ein Probetag macht das Ganze konkret - dann der Vertrag.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="container-rd relative">
      <div class="text-center max-w-3xl mx-auto">
        <span class="eyebrow eyebrow-light">Werden Sie Teil der Geschichte</span>
        <h2 class="heading-xl mt-4 text-balance" style="color:#fff">
          Wir freuen uns auf
          <span class="accent-brand"> Ihre Bewerbung.</span>
        </h2>
        <p class="lead-on-dark mt-5 text-pretty">
          Per E-Mail an Anja Mädel - sie meldet sich persönlich. Lieber erst telefonieren? Auch gut.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a href={`mailto:${site.emailBewerbung}?subject=${encodeURIComponent('Bewerbung Klotz+Wedekind')}`} class="btn btn-primary btn-lg">
            <Icon name="Mail" size={17} strokeWidth={2.2} />
            {site.emailBewerbung}
          </a>
          <a href="tel:+494073483150" class="btn btn-on-dark btn-lg">
            <Icon name="Phone" size={17} strokeWidth={2.2} />
            Anja Mädel · 040 - 734 83 - 150
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Stats-Strip */
  .jobs-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgb(var(--rgb-line));
    border: 1px solid rgb(var(--rgb-line));
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .jobs-stats { grid-template-columns: repeat(4, 1fr); }
  }
  .jobs-stat {
    padding: 1.65rem 1.4rem;
    background: #fff;
    text-align: center;
  }
  .jobs-stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 3.2vw, 2.5rem);
    font-weight: 800;
    color: rgb(var(--rgb-brand));
    line-height: 1;
    letter-spacing: -0.022em;
  }
  .jobs-stat-label {
    display: block;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(var(--rgb-muted));
    margin-top: 0.4rem;
  }

  /* Job-List */
  .job-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .job-detail-card {
    padding: 2rem 1.85rem;
    background: linear-gradient(135deg, #fff 0%, rgb(var(--rgb-paper)) 100%);
    border: 1px solid rgb(var(--rgb-line));
    border-radius: var(--r-lg);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }
  .job-detail-card:hover {
    border-color: rgb(var(--rgb-brand) / 0.36);
    box-shadow: 0 18px 44px -18px rgb(23 23 23 / 0.18);
  }
  .job-detail-head {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    margin-bottom: 1rem;
  }
  .job-detail-icon {
    width: 56px; height: 56px;
    flex-shrink: 0;
    border-radius: 12px;
    background: linear-gradient(135deg, rgb(var(--rgb-brand) / 0.14), rgb(var(--rgb-brand) / 0.04));
    border: 1px solid rgb(var(--rgb-brand) / 0.22);
    color: rgb(var(--rgb-brand));
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .job-detail-cat {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--rgb-brand));
    margin-bottom: 0.3rem;
  }
  .job-detail-title {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 1.4rem;
    color: rgb(var(--rgb-ink));
    letter-spacing: -0.012em;
    margin: 0;
    line-height: 1.15;
  }
  .job-detail-intro {
    font-size: 1rem;
    line-height: 1.6;
    color: rgb(var(--rgb-ink-soft));
    margin: 0 0 1.5rem;
  }
  .job-detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding-top: 1.2rem;
    padding-bottom: 1.4rem;
    border-top: 1px solid rgb(var(--rgb-line));
    border-bottom: 1px solid rgb(var(--rgb-line));
    margin-bottom: 1.4rem;
  }
  @media (min-width: 768px) {
    .job-detail-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  }
  .job-detail-h {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--rgb-brand-deep));
    margin-bottom: 0.85rem;
  }
  .job-detail-list {
    list-style: none;

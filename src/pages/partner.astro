---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { site, telLink, mailLink } from '../data/site';

const partner = [
  { name: 'Al-Ko',         desc: 'Servicepartner für PKW-Anhänger sowie Wohnmobile und Caravan.' },
  { name: 'Bär Cargolift', desc: 'Neubau, Wartung, Reparatur und Service sowie UVV-Prüfungen für Ladebordwände.' },
  { name: 'Dhollandia',    desc: 'Neubau, Wartung, Reparatur, Service und UVV-Abnahmen für Hubsysteme.' },
  { name: 'Fischer Fahrzeugwerke', desc: 'Vertriebs- und Wartungspartner für Vertriebs- und Servicefahrzeuge.' },
  { name: 'Gigant',        desc: 'Servicepartner für Reparatur und Wartung an Anhängern und Aufliegern.' },
  { name: 'Hiab',          desc: 'Neubau, Reparatur und Wartung sowie UVV-Prüfungen für Krane.' },
  { name: 'Hyva',          desc: 'Neubau, Reparatur, Wartung, Service und UVV-Abnahmen für Hydrauliksysteme.' },
  { name: 'Lamberet',      desc: 'Servicepartner für Kühlfahrzeug-Neubau und Service.' },
  { name: 'Meiller Liftsystems', desc: 'Servicepartner für Wartung, Reparatur und UVV-Prüfungen.' },
  { name: 'Palfinger Tail Lifts GmbH', desc: 'Neubau, Wartung, Reparatur, Service und UVV-Abnahmen.' },
  { name: 'Sörensen',      desc: 'Neubau, Wartung, Reparatur, Service und UVV-Prüfungen.' },
];
---

<Layout
  title={`Partner - ${site.name}`}
  description="Servicepartner für Krane, Ladebordwände, Anhänger, Auflieger und Kühlaufbauten. Markenoffene Werkstatt mit Spezialisierung auf Nutzfahrzeug-Technik."
  current="partner"
>

  <!-- Hero -->
  <section class="subpage-hero ink-grid">
    <div class="container-rd relative pt-32 md:pt-40 pb-12 md:pb-16">
      <div class="max-w-3xl">
        <span class="eyebrow eyebrow-light">Service-Partnerschaften · UVV-Prüfungen</span>
        <h1 class="heading-display mt-4 text-balance" style="color:#fff">
          Servicepartner
          <span class="accent-brand"> der besten Marken.</span>
        </h1>
        <p class="lead-on-dark mt-5 max-w-2xl text-pretty">
          Markenoffen und doch tief verzahnt: Wir sind anerkannte Servicepartner für die führenden
          Hersteller im Nutzfahrzeug-Bereich. Krane, Ladebordwände, Kühlsysteme und Hydraulik.
        </p>
      </div>
    </div>
  </section>

  <!-- Partner-Grid -->
  <section class="section">
    <div class="container-rd">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {partner.map((p) => (
          <article class="partner-card">
            <div class="partner-card-mark">{p.name.split(' ')[0].charAt(0)}{p.name.split(' ').length > 1 ? p.name.split(' ')[1].charAt(0) : ''}</div>
            <div class="flex-1">
              <h3 class="partner-card-name">{p.name}</h3>
              <p class="partner-card-desc">{p.desc}</p>
            </div>
            <span class="partner-card-icon"><Icon name="ShieldCheck" size={20} strokeWidth={2} /></span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- UVV-Hinweis -->
  <section class="section section-paper-deep">
    <div class="container-rd">
      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 items-center">
        <div>
          <span class="eyebrow">UVV-Prüfungen</span>
          <h2 class="heading-xl mt-4 text-balance">
            Sicherheit
            <span class="accent-brand"> nach Vorschrift.</span>
          </h2>
          <p class="lead mt-5 text-pretty">
            Krane, Ladebordwände, Hubsysteme - alle UVV-Prüfungen werden bei Klotz + Wedekind im Haus
            durchgeführt. Schnell, vollständig und mit dokumentiertem Prüfprotokoll.
          </p>
          <p class="lead mt-4 text-pretty">
            Als amtlich anerkannte Werkstatt und GTÜ-Stützpunkt verbinden wir Service mit Prüfung -
            ohne Werkstattwechsel.
          </p>
        </div>

        <div class="space-y-3">
          <div class="info-card">
            <span class="info-card-icon"><Icon name="ShieldCheck" size={22} strokeWidth={2} /></span>
            <div class="flex-1">
              <strong class="block text-ink text-[1.05rem] font-extrabold mb-0.5" style="letter-spacing:-0.012em">UVV-Prüfung Krane</strong>
              <span class="text-ink-soft text-sm leading-relaxed">Hiab, Palfinger, Hyva - Erstabnahme und wiederkehrende Prüfungen.</span>
            </div>
          </div>
          <div class="info-card">
            <span class="info-card-icon"><Icon name="ArrowLeftRight" size={22} strokeWidth={2} /></span>
            <div class="flex-1">
              <strong class="block text-ink text-[1.05rem] font-extrabold mb-0.5" style="letter-spacing:-0.012em">UVV-Prüfung Ladebordwände</strong>
              <span class="text-ink-soft text-sm leading-relaxed">Bär, Dhollandia, Meiller, Sörensen - dokumentiert nach Vorschrift.</span>
            </div>
          </div>
          <div class="info-card">
            <span class="info-card-icon"><Icon name="Zap" size={22} strokeWidth={2} /></span>
            <div class="flex-1">
              <strong class="block text-ink text-[1.05rem] font-extrabold mb-0.5" style="letter-spacing:-0.012em">Hydraulik-Service</strong>
              <span class="text-ink-soft text-sm leading-relaxed">Reparatur und Service an allen gängigen Hydrauliksystemen.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta ink-grid">
    <div class="container-rd relative">
      <div class="text-center max-w-3xl mx-auto">
        <span class="eyebrow eyebrow-light">UVV oder Reparatur fällig?</span>
        <h2 class="heading-xl mt-4 text-balance" style="color:#fff">
          Wir sind Ihr
          <span class="accent-brand"> Service-Partner.</span>
        </h2>
        <p class="lead-on-dark mt-5 text-pretty">
          Rufen Sie an für einen Termin. Wir koordinieren UVV-Prüfung und etwaige Reparaturen in einem Werkstatt-Stop.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a href={telLink} class="btn btn-primary btn-lg">
            <Icon name="Phone" size={17} strokeWidth={2.2} />
            {site.phoneDisplay}
          </a>
          <a href={mailLink} class="btn btn-on-dark btn-lg">
            <Icon name="Mail" size={17} strokeWidth={2.2} />
            E-Mail schreiben
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .partner-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 1.5rem;
    background: linear-gradient(135deg, #fff 0%, rgb(var(--rgb-paper)) 100%);
    border: 1px solid rgb(var(--rgb-line));
    border-radius: var(--r-lg);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .partner-card:hover {
    transform: translateY(-3px);
    border-color: rgb(var(--rgb-brand) / 0.36);
    box-shadow: 0 14px 36px -14px rgb(23 23 23 / 0.16);
  }
  .partner-card-mark {
    width: 56px; height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgb(var(--rgb-brand) / 0.92), rgb(var(--rgb-brand-deep)));
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.014em;
    box-shadow: 0 6px 18px -4px rgb(var(--rgb-brand) / 0.5);
    flex-shrink: 0;
  }
  .partner-card-name {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 1.1rem;
    color: rgb(var(--rgb-ink));
    letter-spacing: -0.012em;
    margin: 0 0 0.25rem;
    line-height: 1.15;
  }
  .partner-card-desc {
    font-size: 0.86rem;
    line-height: 1.5;
    color: rgb(var(--rgb-ink-soft));
    margin: 0;
  }
  .partner-card-icon {
    width: 36px; height: 36px;
    border-radius: 9px;
    background: rgb(var(--rgb-brand) / 0.08);
    color: rgb(var(--rgb-brand));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { site, telLink, mailLink } from '../../data/site';
import { services } from '../../data/services';
---

<Layout
  title={`Leistungen - ${site.name} Hamburg-Wilhelmsburg`}
  description="Karosserie & Fahrzeugbau, Nutzfahrzeug-Service, Reparatur & Unfallinstandsetzung, Lackiererei, Rahmenrichtstand, Wohnmobil & Caravan - alles aus einer Hand."
  current="leistungen"
>

  <!-- Hero -->
  <section class="subpage-hero ink-grid">
    <div class="container-rd relative pt-32 md:pt-40 pb-12 md:pb-16">
      <div class="max-w-3xl">
        <span class="eyebrow eyebrow-light">Sechs Leistungsbereiche · Ein Ansprechpartner</span>
        <h1 class="heading-display mt-4 text-balance" style="color:#fff">
          Alles
          <span class="accent-brand"> aus einer Hand.</span>
        </h1>
        <p class="lead-on-dark mt-5 max-w-2xl text-pretty">
          Sie haben nur einen Ansprechpartner: Klotz + Wedekind kümmert sich um Ihre Belange in allen Bereichen.
          Vom Karosseriebau über die HU-Abnahme bis zur Wohnmobil-Reparatur.
        </p>
      </div>
    </div>
  </section>

  <!-- 6 Leistungs-Cards -->
  <section class="section">
    <div class="container-rd">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {services.map((s) => (
          <a href={s.href} class="leistungs-card">
            <span class="leistungs-card-icon">
              <Icon name={s.iconName} size={26} strokeWidth={1.9} />
            </span>
            <span class="leistungs-card-cat">{s.cat}</span>
            <h2 class="leistungs-card-title">{s.title}</h2>
            <p class="leistungs-card-text">{s.short}</p>
            {s.quote && <span class="leistungs-card-quote">{s.quote}</span>}
            <span class="leistungs-card-link">
              Mehr erfahren
              <Icon name="ArrowRight" size={14} strokeWidth={2.2} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section-paper-deep">
    <div class="container-rd">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="eyebrow">Heritage zählt</span>
        <h2 class="heading-xl mt-4 text-balance">
          115 Jahre Tradition.
          <span class="accent-brand"> Drei Generationen.</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        {site.stats.map((stat) => (
          <div class="stat-card">
            <span class="stat-card-value">{stat.value}</span>
            <span class="stat-card-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta ink-grid">
    <div class="container-rd relative">
      <div class="text-center max-w-3xl mx-auto">
        <span class="eyebrow eyebrow-light">Jetzt sprechen</span>
        <h2 class="heading-xl mt-4 text-balance" style="color:#fff">
          Welche Leistung
          <span class="accent-brand"> brauchen Sie?</span>
        </h2>
        <p class="lead-on-dark mt-5 text-pretty">
          Rufen Sie an oder schreiben Sie eine E-Mail. Wir besprechen die Details persönlich.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a href={telLink} class="btn btn-primary btn-lg">
            <Icon name="Phone" size={17} strokeWidth={2.2} />
            {site.phoneDisplay}
          </a>
          <a href={mailLink} class="btn btn-on-dark btn-lg">
            <Icon name="Mail" size={17} strokeWidth={2.2} />
            E-Mail schreiben
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .leistungs-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2rem 1.85rem 1.85rem;
    background: linear-gradient(135deg, #fff 0%, rgb(var(--rgb-paper)) 100%);
    border: 1px solid rgb(var(--rgb-line));
    border-radius: var(--r-lg);
    transition: transform 0.3s ease, border-color 0.25s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }
  .leistungs-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, rgb(var(--rgb-brand)), rgb(var(--rgb-accent)));
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.4s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .leistungs-card:hover {
    transform: translateY(-4px);
    border-color: rgb(var(--rgb-brand) / 0.4);
    box-shadow: 0 18px 44px -16px rgb(23 23 23 / 0.2);
  }
  .leistungs-card:hover::before { transform: scaleX(1); }
  .leistungs-card-icon {
    width: 54px; height: 54px;
    border-radius: var(--r-md);
    background: linear-gradient(135deg, rgb(var(--rgb-brand) / 0.14), rgb(var(--rgb-accent) / 0.08));
    border: 1px solid rgb(var(--rgb-brand) / 0.24);
    color: rgb(var(--rgb-brand));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .leistungs-card:hover .leistungs-card-icon {
    transform: rotate(-6deg) scale(1.04);
    box-shadow: 0 8px 22px -8px rgb(var(--rgb-brand) / 0.5);
  }
  .leistungs-card-cat {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(var(--rgb-brand));
  }
  .leistungs-card-title {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 1.35rem;
    line-height: 1.15;
    color: rgb(var(--rgb-ink));
    letter-spacing: -0.014em;
    margin: 0;
  }
  .leistungs-card-text {
    color: rgb(var(--rgb-ink-soft));
    font-size: 0.94rem;
    line-height: 1.55;
    margin: 0;
  }
  .leistungs-card-quote {
    display: inline-block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: 0.92rem;
    color: rgb(var(--rgb-brand-deep));
    padding-left: 0.7rem;
    border-left: 2px solid rgb(var(--rgb-brand));
    margin-top: 0.3rem;
  }
  .leistungs-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.85rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(var(--rgb-brand-deep));
    transition: gap 0.25s ease;
  }
  .leistungs-card:hover .leistungs-card-link { gap: 0.6rem; }

  /* Stat-Card */
  .stat-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.65rem 1.25rem;
    background: #fff;
    border: 1px solid rgb(var(--rgb-line));
    border-radius: var(--r-lg);
    text-align: center;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .stat-card:hover {
    transform: translateY(-2px);
    border-color: rgb(var(--rgb-brand) / 0.3);
  }
  .stat-card-value {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: rgb(var(--rgb-brand));
    line-height: 1;
    letter-spacing: -0.022em;
  }
  .stat-card-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--rgb-muted));
  }
</style>

---
import {
  Droplets, Sparkles, HandMetal, Wind, Fuel,
  Sun, Zap, CircleDot, Disc3,
  Clock, Phone, PhoneCall, Mail, MapPin, Navigation,
  UserRound, Award, ShieldCheck, BadgeCheck,
  MoveHorizontal, MoveVertical, ArrowDownToLine,
  ArrowRight, ArrowUpRight, ChevronRight, ChevronDown, ChevronUp,
  Menu, X, Check, CircleCheck, CircleAlert,
  Calendar, Car, ExternalLink, FileText, AlertTriangle,
  MessageCircle, Quote, Pin, Send,
  CalendarClock, Timer, ScanLine, ParkingCircle, Tag,
} from '@lucide/astro';

const MAP: Record<string, any> = {
  Droplets, Sparkles, HandMetal, Wind, Fuel,
  Sun, Zap, CircleDot, Disc3,
  Clock, Phone, PhoneCall, Mail, MapPin, Navigation,
  UserRound, Award, ShieldCheck, BadgeCheck,
  MoveHorizontal, MoveVertical, ArrowDownToLine,
  ArrowRight, ArrowUpRight, ChevronRight, ChevronDown, ChevronUp,
  Menu, X, Check, CircleCheck, CircleAlert,
  Calendar, Car, ExternalLink, FileText, AlertTriangle,
  MessageCircle, Quote, Pin, Send,
  CalendarClock, Timer, ScanLine, ParkingCircle, Tag,
};

interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}
const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
const Cmp = MAP[name] ?? CircleDot;
---
<Cmp size={size} class={className} stroke-width={strokeWidth} />
